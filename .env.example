# Frontend → API base URL.
# In dev you can leave this unset: requests go to '/api' and Vite proxies
# them to the backend (see vite.config.js). Set it in production to the
# deployed API's full URL, e.g. https://api.prakruti.in/api
# VITE_API_URL=https://your-api-host/api

# Dev only: where Vite proxies '/api' to (defaults to http://localhost:4500)
# VITE_API_PROXY=http://localhost:4500

# Backend
PORT=4500
JWT_SECRET=change-this-to-a-long-random-string-in-production
